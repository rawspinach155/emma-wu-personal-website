{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "emma-wu-little-plaza",
  "compatibility_date": "2026-07-21",
  "main": "./worker/index.ts",
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "none",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  }
}
